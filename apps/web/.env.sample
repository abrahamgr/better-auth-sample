# Copy this file to .env and fill in your values.
# Generate a secret: openssl rand -base64 32

# ── Application ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
# Must be at least 32 characters.
BETTER_AUTH_SECRET=change-me-to-a-strong-random-secret-32ch

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/better_auth_sample

# ── Email: SMTP (required when NODE_ENV is not 'production') ─────────────────
# Local Mailpit defaults — run `pnpm db:up` to start it.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=Better Auth Sample <noreply@local.test>

# ── Email: Resend (required when NODE_ENV='production') ──────────────────────
# In production, emails are sent via Resend and SMTP_* vars are ignored.
# RESEND_API_KEY=re_...

# ── Logging ───────────────────────────────────────────────────────────────────
# Allowed: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
