{
  "name": "@workspace/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --port 3000",
    "build": "react-router build",
    "start": "PORT=3000 react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:generate": "better-auth generate --config ./app/lib/auth.server.ts --output ./app/lib/db/auth-schema.ts -y"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.5",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.39",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-router": "^7.14.1",
    "resend": "^6.12.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@react-router/dev": "^7.14.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
